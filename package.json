{
  "name": "compose-docs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "generate:docs-index": "node scripts/generate-docs-index.mjs",
    "dev": "npm run generate:docs-index && vite",
    "prerender:routes": "node scripts/prerender-routes.mjs",
    "generate:seo-assets": "node scripts/generate-seo-assets.mjs",
