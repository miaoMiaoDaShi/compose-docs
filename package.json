    "preview": "vite preview"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^12.0.0",
    "marked-highlight": "^2.2.3",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0"
  }
